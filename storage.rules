rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Chaque utilisateur peut accéder uniquement à son propre dossier
    match /users/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;
    }
    // Les fichiers RAG (Markdown Bible) sont en lecture seule pour les utilisateurs authentifiés
    match /rag/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if false; // Écriture uniquement via Cloud Functions
    }
  }
}
